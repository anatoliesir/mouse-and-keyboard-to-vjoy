<Window x:Class="MouseToVJoy.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MouseToVJoy.Views"
        mc:Ignorable="d"
        Title="Help &amp; About - MouseToVJoy" 
        Height="550" Width="480" 
        Background="#1E1E1E" Foreground="#E0E0E0"
        FontFamily="Segoe UI" ResizeMode="NoResize" WindowStyle="ThreeDBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="MouseToVJoy Application" FontSize="22" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,15"/>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <StackPanel>

                <!--Important-->
                <TextBlock Text="Important:" FontSize="14" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,5"/>
                <TextBlock Text="To make this program work, you need to instal vJoy!! Go on my github repository(github.com/anatoliesir/mouse-and-keyboard-to-vjoy), and find the BrunnerInnovation release link." 
                            TextWrapping="Wrap" LineHeight="18" Foreground="#CCCCCC" Margin="0,0,0,15"/>

                <Separator Background="#333333" Margin="0,0,0,15"/>
                <!-- Description -->
                <TextBlock Text="Description" FontSize="14" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,5"/>
                <TextBlock Text="MouseToVJoy is an application designed to emulate a virtual joystick (vJoy) using mouse movements and keyboard inputs. It provides smooth and progressive control, making it ideal for simracing games where steering precision is critical." 
                           TextWrapping="Wrap" LineHeight="18" Foreground="#CCCCCC" Margin="0,0,0,15"/>

                <Separator Background="#333333" Margin="0,0,0,15"/>

                <!-- Control Modes -->
                <TextBlock Text="Recommended Control Modes" FontSize="14" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,10"/>

                <StackPanel Margin="5,0,0,15">
                    <TextBlock Text="• Keyboard + Mouse (Recommended):" FontWeight="SemiBold" Foreground="#FFD369" Margin="0,0,0,2"/>
                    <TextBlock Text="Throttle and Brake on the keyboard, Steering on the mouse." Margin="15,0,0,8" TextWrapping="Wrap"/>

                    <TextBlock Text="• Mouse Only:" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,2"/>
                    <TextBlock Text="Mouse used entirely for Steering, Throttle, and Brake." Margin="15,0,0,8" TextWrapping="Wrap"/>

                    <TextBlock Text="• Hybrid:" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,2"/>
                    <TextBlock Text="Throttle mapped to the keyboard, while Brake and Steering are controlled via the mouse for a much more precise braking modulation in corners." Margin="15,0,0,0" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </StackPanel>

                <Separator Background="#333333" Margin="0,0,0,15"/>

                <!-- Options Explanation -->
                <TextBlock Text="Main Options Explained" FontSize="14" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,10"/>

                <StackPanel Margin="5,0,0,15">
                    <TextBlock Text="Lag Up/Down" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Controls the response time (press/release speed) of the virtual pedals. It is recommended for smoothing out digital (on/off) keyboard input and preventing traction loss during sudden acceleration or heavy braking." Margin="0,2,0,10" TextWrapping="Wrap" FontSize="12" Foreground="#B0B0B0"/>

                    <TextBlock Text="Return Time" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Specifies the speed at which the steering axis returns to the neutral position (center) when no mouse movement is detected. Adjusting this helps stabilize the car when exiting corners." Margin="0,2,0,10" TextWrapping="Wrap" FontSize="12" Foreground="#B0B0B0"/>

                    <TextBlock Text="Response Curves" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Modifies input linearity. A progressive curve (e.g., Gamma/Exponential) offers reduced sensitivity and maximum precision around the center (for straight lines and micro-corrections) and a more aggressive response during large movements." Margin="0,2,0,10" TextWrapping="Wrap" FontSize="12" Foreground="#B0B0B0"/>

                    <TextBlock Text="Assists" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Filtering algorithms designed to compensate for the lack of physical peripherals. They filter out jittery mouse movements and help maintain a stable racing line at high speeds." Margin="0,2,0,0" TextWrapping="Wrap" FontSize="12" Foreground="#B0B0B0"/>
                </StackPanel>

                <Separator Background="#333333" Margin="0,0,0,15"/>

                <TextBlock Text="Notes" FontSize="14" FontWeight="Bold" Foreground="#FFD369" Margin="0,0,0,10"/>
                <Border Background="#252525" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="• Boosted performance in simracing is not guaranteed. Better results depend on proper configuration and knowing how to use the assists and controls." 
                                   TextWrapping="Wrap" Margin="0,0,0,8" FontStyle="Italic" FontSize="12"/>
                        <TextBlock Text="• This application was manually designed and developed by Sîrbu Răzvan. AI was used to assist with the development of complex mathematical formulas and algorithms. The forked vJoy driver that was used here was made by BrunnerInnovation from GitHub." 
                                   TextWrapping="Wrap" FontStyle="Italic" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Close Button -->
        <Button Grid.Row="2" Content="Got it" HorizontalAlignment="Right" Padding="20,6" 
                Background="#00ADB5" Foreground="White" FontWeight="Bold" Click="CloseButton_Click" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="4" 
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#00C4CC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
